# Paperwork Genius Premium - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# FRONTEND (exposed to browser via VITE_ prefix)
# ===========================================

# Supabase project URL (from Settings > API in Supabase dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (safe to expose, used for client-side auth)
VITE_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# BACKEND ONLY (Vercel Edge Functions)
# Never expose these to the client!
# ===========================================

# Shovels.ai API key (paid API, use sparingly)
# Get from: https://shovels.ai
SHOVELS_API_KEY=your-shovels-api-key

# Supabase service role key (full database access for data loading)
# DANGER: Never expose this in client code!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase URL (for server-side scripts)
SUPABASE_URL=https://your-project.supabase.co
